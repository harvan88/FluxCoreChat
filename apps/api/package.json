{
  "name": "@fluxcore/api",
  "version": "0.1.0",
  "description": "FluxCore API - Backend con Elysia",
  "type": "module",
  "scripts": {
    "kernel:dev": "FLUXCORE_ROLE=worker bun --env-file ../../.env --watch src/kernel-runtime.ts",
    "api:dev": "FLUXCORE_ROLE=api bun --env-file ../../.env --watch src/server.ts",
    "dev": "bun run api:dev",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "start": "FLUXCORE_ROLE=api bun run dist/server.js",
    "kernel:start": "FLUXCORE_ROLE=worker bun --env-file ../../.env src/kernel-runtime.ts",
    "lint": "tsc --noEmit -p tsconfig.lint.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@elysiajs/cors": "0.8.0",
    "@elysiajs/jwt": "0.8.0",
    "@elysiajs/swagger": "0.8.5",
    "@fluxcore/db": "workspace:*",
    "@fluxcore/types": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.10.2",
    "croner": "^9.1.0",
    "elysia": "0.8.17",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.4.2",
    "luxon": "^3.7.2",
    "openai": "^6.16.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.10.0",
    "bun-types": "^1.0.0",
    "chokidar": "^5.0.0",
    "typescript": "^5.3.3"
  }
}
